@{
    var disciplinas = ViewBag.Disciplinas as List<string> ?? new List<string>();
    var notas = ViewBag.Notas as List<double> ?? new List<double>();

    double soma = 0;
}

<h2>Boletim de Notas</h2>

<table border="1" cellpadding="10">
    <tr>
        <th>Disciplina</th>
        <th>Nota</th>
        <th>Status</th>
        <th>Classificação</th>
    </tr>

    @for (int i = 0; i < disciplinas.Count; i++)
    {
        soma += notas[i];

        <tr>
            <td>@disciplinas[i]</td>
            <td>@notas[i]</td>

            <td>
                @if (notas[i] >= 6)
                {
                    <span style="color:green">Aprovado</span>
                }
                else
                {
                    <span style="color:red">Reprovado</span>
                }
            </td>

            <td>
                @switch ((int)notas[i])
                {
                    case int n when n >= 9:
                        <span>A</span>
                        break;

                    case int n when n >= 7:
                        <span>B</span>
                        break;

                    case int n when n >= 5:
                        <span>C</span>
                        break;

                    default:
                        <span>D</span>
                        break;
                }
            </td>
        </tr>
    }
</table>

<h3>Média Geral: @(soma / notas.Count)</h3>